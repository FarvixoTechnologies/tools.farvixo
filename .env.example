# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (public — safe for browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only — never expose to client)
# Required for: newsletter, contact form, analytics, search logs, Stripe webhook
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini AI (server-only) — powers /api/ai/chat
GEMINI_API_KEY=

# Stripe (server-only) — powers Upgrade to Pro
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=

# ─── Share link cron cleanup ─────────────────────────────────────────────────
# Random string (e.g. openssl rand -hex 32). Vercel Cron calls:
#   GET https://toolnestfm.com/api/cron/cleanup-shares
#   Header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
