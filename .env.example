# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (public — safe for browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase (server-only — never expose to client)
# Required for: newsletter, contact form, analytics, search logs, Stripe webhook
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Auth → Google (paste into Dashboard → Authentication → Providers → Google)
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_CLIENT_SECRET=

# Supabase Auth → GitHub (paste into Dashboard → Authentication → Providers → GitHub)
SUPABASE_AUTH_GITHUB_CLIENT_ID=
SUPABASE_AUTH_GITHUB_CLIENT_SECRET=

# Google Gemini AI (server-only) — primary free tier for all users
GEMINI_API_KEY=

# Groq free tier (optional fallback) — console.groq.com — Llama 3.3 70B, 30 req/min
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter free models (optional fallback) — openrouter.ai — no credit card
OPENROUTER_API_KEY=
OPENROUTER_FREE_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Stripe (server-only) — powers Upgrade to Pro
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO_MONTHLY=

# ─── Share link cron cleanup ─────────────────────────────────────────────────
# Random string (e.g. openssl rand -hex 32). Cloudflare Cron / worker calls:
#   GET https://tools.farvixo.com/api/cron/cleanup-shares
#   Header: Authorization: Bearer <CRON_SECRET>
# Hosting = Cloudflare Pages (not Vercel). See docs/NEXT_STEPS_BN.md §8.
CRON_SECRET=

# WeatherAPI.com (server-only, optional) — enriches World Weather Pro with severe alerts + moonrise/moonset. Free key at weatherapi.com. Without it the tool still works via Open-Meteo.
WEATHERAPI_KEY=
